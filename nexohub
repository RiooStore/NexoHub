local placeConnection
local upgradeHookActive = false

local function AktifkanHybridSniffer()
    -- 1. DETEKSI PLACE (Lewat Workspace - 100% Anti Sampah Klik)
    if TowerFolder then
        placeConnection = TowerFolder.ChildAdded:Connect(function(child)
            if not isRecording then return end
            task.wait(0.1)
            local ownerCheck = child:FindFirstChild("Owner") or child:FindFirstChild("Player")
            if ownerCheck and ownerCheck.Value ~= LocalPlayer.Name then return end
            
            local primaryPart = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
            if primaryPart then
                local currentDelay = os.clock() - StartTime
                table.insert(MacroData, {
                    Type = "Spawn",
                    Time = currentDelay,
                    X = primaryPart.Position.X,
                    Y = primaryPart.Position.Y,
                    Z = primaryPart.Position.Z,
                    SavedUID = LastSelectedUnitUID
                })
                appendZoneLog("Place", "Tower placement captured successfully!")
            end
        end)
    end

    -- 2. DETEKSI UPGRADE (Mencegat Remote Upgrade secara pasif & aman)
    if not upgradeHookActive then
        upgradeHookActive = true
        local upgradeRemote = getSafeRemote("UpgradeTower") or getSafeRemote("Upgrade")
        if upgradeRemote then
            local originalNamecall
            originalNamecall = hookmetatable(game, {
                __namecall = newcclosure(function(self, ...)
                    local method = getnamecallmethod()
                    local args = {...}
                    
                    if isRecording and self == upgradeRemote and (method == "FireServer" or method == "InvokeServer") then
                        -- Cari argumen koordinat Vector3 dari remote game lu
                        local pos = nil
                        for _, arg in pairs(args) do
                            if typeof(arg) == "Vector3" then
                                pos = arg
                                break
                            elseif typeof(arg) == "table" and arg.X and arg.Y and arg.Z then
                                pos = Vector3.new(arg.X, arg.Y, arg.Z)
                                break
                            end
                        end
                        
                        -- Kalau argumennya berupa model tower, kita ambil posisinya
                        if not pos and typeof(args[1]) == "Instance" and args[1]:IsA("Model") then
                            local part = args[1].PrimaryPart or args[1]:FindFirstChildWhichIsA("BasePart")
                            if part then pos = part.Position end
                        end

                        if pos then
                            local currentDelay = os.clock() - StartTime
                            table.insert(MacroData, {
                                Type = "Upgrade",
                                Time = currentDelay,
                                X = pos.X,
                                Y = pos.Y,
                                Z = pos.Z
                            })
                            appendZoneLog("Upgrade", "Upgrade action captured via secure bridge!")
                        end
                    end
                    return originalNamecall(self, ...)
                end)
            })
        end
    end
end

