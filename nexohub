local function jalankanPlayback()
    if #MacroData == 0 then return end
    appendZoneLog("Play", "Deploying hybrid playback...")
    task.spawn(function()
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            while (os.clock() - playbackStart) < step.Time do task.wait(0.01) end
            
            if step.Type == "Spawn" then
                local placeRemote = getSafeRemote("PlaceTower") or getSafeRemote("Place")
                if placeRemote then
                    local finalArgs = {[1] = Vector3.new(step.X, step.Y, step.Z), [2] = step.SavedUID, [3] = 0}
                    task.spawn(function()
                        if placeRemote:IsA("RemoteFunction") then placeRemote:InvokeServer(unpack(finalArgs)) else placeRemote:FireServer(unpack(finalArgs)) end
                    end)
                    appendZoneLog("Spawn", string.format("Unit entry %d executed.", index))
                end
            elseif step.Type == "Upgrade" then
                local upgradeRemote = getSafeRemote("UpgradeTower") or getSafeRemote("Upgrade")
                if upgradeRemote then
                    -- Playback otomatis mengirim ulang data upgrade sesuai posisi asal koordinatnya
                    local finalArgs = {[1] = Vector3.new(step.X, step.Y, step.Z)}
                    task.spawn(function()
                        if upgradeRemote:IsA("RemoteFunction") then upgradeRemote:InvokeServer(unpack(finalArgs)) else upgradeRemote:FireServer(unpack(finalArgs)) end
                    end)
                    appendZoneLog("Upgrade", string.format("Upgrade entry %d executed.", index))
                end
            end
        end
        appendZoneLog("System", "Playback automation complete.")
    end)
end
createZoneButton("RUN AUTOMATION", UDim2.new(0, 10, 0, 115), UDim2.new(1, -20, 0, 32), LeftBox, jalankanPlayback)

