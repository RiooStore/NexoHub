local SpeedBtn

local function paksaSpeedGame(targetSpeed)
    if SpeedEvent then
        task.spawn(function()
            SpeedEvent:FireServer(targetSpeed)
            task.wait(0.2)
            SpeedEvent:FireServer(targetSpeed)
        end)
    end
end

createZoneButton("START MACRO RECORD", UDim2.new(0, 10, 0, 38), UDim2.new(1, -20, 0, 32), LeftBox, function()
    if not isRecording then
        MacroData = {}
        StartTime = os.clock()
        isRecording = true
        updateLog("• Status: 🔴 RECORDING ACTIVE\n• Info: Place units down now.")
        
        local clickCon
        clickCon = game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
            if not isRecording then clickCon:Disconnect() return end
            if processed then return end
            
            if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and canRecordClick then
                canRecordClick = false
                local currentDelay = os.clock() - StartTime
                local exactPos = Mouse.Hit.Position 
                
                table.insert(MacroData, {Time = currentDelay, X = exactPos.X, Y = exactPos.Y, Z = exactPos.Z})
                updateLog(string.format("• Status: Locked Unit %d\n• Timestamp: %.2fs", #MacroData, currentDelay))
                
                task.wait(1.2)
                canRecordClick = true
            end
        end)
    else
        isRecording = false
        if #MacroData > 0 then
            if writefile then
                writefile(FILE_NAME, HttpService:JSONEncode(MacroData))
                updateLog(string.format("• Status: 💾 SAVED!\n• Total units locked: %d", #MacroData))
            end
        else
            updateLog("• Status: ❌ Error: Process canceled. Empty data.")
        end
    end
end)

local function muatDataMakro()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        updateLog(string.format("• Status: 📂 MACRO LOADED\n• Total ready: %d units", #MacroData))
        return true
    else
        updateLog("• Status: ❌ Error: Saved file not found.")
        return false
    end
end
createZoneButton("LOAD DATA FROM TEXT", UDim2.new(0, 10, 0, 78), UDim2.new(1, -20, 0, 32), LeftBox, muatDataMakro)

local function jalankanPlayback()
    if #MacroData == 0 then
        updateLog("• Status: ❌ Error: Empty queue. Load text first.")
        return
    end
    updateLog("• Status: 🔵 PLAYBACK RUNNING...")
    task.spawn(function()
        paksaSpeedGame(currentSpeedSetting)
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            while (os.clock() - playbackStart) < step.Time do task.wait(0.01) end
            if PlaceEvent then
                local finalArgs = {
                    [1] = Vector3.new(step.X, step.Y, step.Z),
                    [2] = "ffc541d5-ef02-4a69-8045-6a3d97bda308", 
                    [3] = 0
                }
                task.spawn(function() PlaceEvent:InvokeServer(unpack(finalArgs)) end)
                updateLog(string.format("• Status: Deploying sequence %d / %d", index, #MacroData))
            end
        end
        updateLog("• Status: 🏁 All units spawned! Waiting match end.")
        
        if autoReplayEnabled then
            while autoReplayEnabled do
                task.wait(2)
                if ReplayEvent then
                    ReplayEvent:FireServer()
                    updateLog("• Status: Victory! Rejoining...")
                    break
                end
            end
        end
    end)
end
createZoneButton("RUN AUTOMATION", UDim2.new(0, 10, 0, 118), UDim2.new(1, -20, 0, 32), LeftBox, jalankanPlayback)

