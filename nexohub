-- Folder tempat unit berada (Menyesuaikan game Tower Defense)
local function getTowerFolder()
    return Workspace:FindFirstChild("Towers") 
        or Workspace:FindFirstChild("Units") 
        or Workspace:FindFirstChild("PlacedTowers") 
        or Workspace
end

-- Ambil Remote Event/Function Game secara aman
local function getGameRemote(name)
    local events = ReplicatedStorage:FindFirstChild("Events") or ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage
    return events:FindFirstChild(name, true)
end

