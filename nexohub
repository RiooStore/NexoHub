local placeConnection = nil
local clickConnection = nil

local function AmbilTowerDariMouse(folder)
    local mouse = LocalPlayer:GetMouse()
    local target = mouse.Target
    if target and target:IsDescendantOf(folder) then
        local obj = target
        while obj and obj.Parent ~= folder do
            obj = obj.Parent
        end
        return obj
    end
    return nil
end

local RecordBtn
RecordBtn = createZoneButton("START MACRO RECORD", UDim2.new(0, 10, 0, 35), UDim2.new(1, -20, 0, 32), LeftBox, function()
    local currentFolder = dapatkanFolderTower()
    
    if not isRecording then
        MacroData = {}
        StartTime = os.clock()
        isRecording = true
        RecordBtn.Text = "🛑 STOP RECORDING"
        RecordBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        appendZoneLog("System", "Recording started. Place or Upgrade your towers now!")
        
        -- 1. Deteksi Placement Tower
        if currentFolder and not placeConnection then
            placeConnection = currentFolder.ChildAdded:Connect(function(child)
                if not isRecording then return end
                task.wait(0.1)
                local primaryPart = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
                if primaryPart then
                    table.insert(MacroData, {
                        Type = "Spawn",
                        Time = os.clock() - StartTime,
                        X = primaryPart.Position.X,
                        Y = primaryPart.Position.Y,
                        Z = primaryPart.Position.Z,
                        SavedUID = LastSelectedUnitUID
                    })
                    appendZoneLog("Place", "Placement logged successfully.")
                end
            end)
        end
        
        -- 2. Deteksi Upgrade via Klik Mouse (Bypass Remote Spy & Anti-Crash)
        clickConnection = LocalPlayer:GetMouse().Button1Down:Connect(function()
            task.wait(0.1) -- Beri jeda tipis agar remote upgrade game kelar duluan
            local tower = AmbilTowerDariMouse(currentFolder)
            if tower then
                local p = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
                if p then
                    table.insert(MacroData, {
                        Type = "Upgrade",
                        Time = os.clock() - StartTime,
                        X = p.Position.X,
                        Y = p.Position.Y,
                        Z = p.Position.Z
                    })
                    appendZoneLog("Upgrade", "Upgrade captured via Tower Position!")
                end
            end
        end)
    else
        isRecording = false
        if placeConnection then placeConnection:Disconnect() placeConnection = nil end
        if clickConnection then clickConnection:Disconnect() clickConnection = nil end
        
        RecordBtn.Text = "START MACRO RECORD"
        RecordBtn.TextColor3 = Color3.fromRGB(240, 240, 240)
        appendZoneLog("System", string.format("Saved moves: %d", #MacroData))
        
        if #MacroData > 0 and writefile then
            writefile(FILE_NAME, HttpService:JSONEncode(MacroData))
        end
    end
end)

createZoneButton("LOAD DATA FROM TEXT", UDim2.new(0, 10, 0, 75), UDim2.new(1, -20, 0, 32), LeftBox, function()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        appendZoneLog("Load", string.format("Loaded %d actions.", #MacroData))
    else
        appendZoneLog("Error", "No macro file found to load.")
    end
end)

createZoneButton("RUN AUTOMATION", UDim2.new(0, 10, 0, 115), UDim2.new(1, -20, 0, 32), LeftBox, function()
    if #MacroData == 0 then appendZoneLog("Error", "No data to play back!") return end
    appendZoneLog("Play", "Deploying macro playback...")
    
    task.spawn(function()
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        local currentFolder = dapatkanFolderTower()
        local upgradeRemote = getSafeRemote("UpgradeTower")
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            while (os.clock() - playbackStart) < step.Time do task.wait(0.01) end
            
            if step.Type == "Spawn" then
                local placeRemote = getSafeRemote("PlaceTower") or getSafeRemote("Place")
                if placeRemote then
                    local finalArgs = {[1] = Vector3.new(step.X, step.Y, step.Z), [2] = step.SavedUID, [3] = 0}
                    task.spawn(function()
                        if placeRemote:IsA("RemoteFunction") then placeRemote:InvokeServer(unpack(finalArgs)) else placeRemote:FireServer(unpack(finalArgs)) end
                    end)
                    appendZoneLog("Spawn", string.format("Placed unit sequence %d.", index))
                end
            elseif step.Type == "Upgrade" and upgradeRemote then
                -- Cari ID Live Tower terdekat dari koordinat lama
                local targetPos = Vector3.new(step.X, step.Y, step.Z)
                local jarakTerdekat = math.huge
                local liveUID = nil
                
                for _, t in pairs(currentFolder:GetChildren()) do
                    local bp = t:FindFirstChildWhichIsA("BasePart") or t.PrimaryPart
                    if bp then
                        local dist = (bp.Position - targetPos).Magnitude
                        if dist < jarakTerdekat and dist < 6 then
                            jarakTerdekat = dist
                            local uidVal = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                            liveUID = uidVal and uidVal.Value or t.Name
                        end
                    end
                end
                
                if liveUID then
                    task.spawn(function()
                        upgradeRemote:InvokeServer(liveUID)
                    end)
                    appendZoneLog("Upgrade", string.format("Upgraded unit sequence %d.", index))
                else
                    appendZoneLog("Error", "Could not cross-reference UID for upgrade.")
                end
            end
        end
        appendZoneLog("System", "AFK Automation Complete.")
    end)
end)

