        end
    end
end)

local function muatDataMakro()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        tambahLogBaris(string.format("[SYSTEM] Loaded macro with %d actions.", #MacroData))
        return true
    end
    return false
end
createZoneButton("LOAD DATA FROM TEXT", UDim2.new(0, 10, 0, 78), UDim2.new(1, -20, 0, 32), LeftBox, muatDataMakro)

local function jalankanPlayback()
    if #MacroData == 0 then return end
    task.spawn(function()
        if speedToggleActive then paksaSpeedGame(currentSpeedSetting) end
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            while (os.clock() - playbackStart) < step.Time do task.wait(0.01) end
            
            if step.Type == "Spawn" and PlaceEvent then
                task.spawn(function() 
                    if PlaceEvent.ClassName == "RemoteEvent" then
                        PlaceEvent:FireServer(unpack(step.Args))
                    else
                        PlaceEvent:InvokeServer(unpack(step.Args))
                    end
                end)
                tambahLogBaris(string.format("[OK] Placed: Unit [S] id=%d", step.Id))
            elseif step.Type == "Upgrade" and UpgradeEvent then
                task.spawn(function()
                    if UpgradeEvent.ClassName == "RemoteEvent" then
                        UpgradeEvent:FireServer(step.TargetId, step.NextLv)
                    else
                        UpgradeEvent:InvokeServer(step.TargetId, step.NextLv)
                    end
                end)
                tambahLogBaris(string.format("[OK] Upgraded slot %d -> lv%d", step.TargetId, step.NextLv))
            end
        end
        tambahLogBaris("[OK] Play finished.")
        
        if autoReplayEnabled then
            while autoReplayEnabled do
                task.wait(2)
                if ReplayEvent then ReplayEvent:FireServer() break end
            end
        end
    end)
end
createZoneButton("RUN AUTOMATION", UDim2.new(0, 10, 0, 118), UDim2.new(1, -20, 0, 32), LeftBox, jalankanPlayback)

