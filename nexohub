    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- =========================================================================
-- LOGIKA UTAMA (HANYA BERJALAN SAAT TOMBOL DIKLIK)
-- =========================================================================
local recordConnection = nil

local function AmbilTowerDariMouse(folder)
    local mouse = LocalPlayer:GetMouse()
    local target = mouse.Target
    if target and target:IsDescendantOf(folder) then
        local obj = target
        while obj and obj.Parent ~= folder do
            obj = obj.Parent
        end
        return obj
    end
    return nil
end

local RecordBtn
RecordBtn = buatTombol("START RECORD", 80, function()
    local currentFolder = dapatkanFolderTower()
    
    if not isRecording then
        MacroData = {}
        StartTime = os.clock()
        isRecording = true
        RecordBtn.Text = "STOP RECORD"
        RecordBtn.BackgroundColor3 = Color3.fromRGB(150, 50, 50)
        updateStatus("Recording... Place/Upgrade now.")
        
        -- Deteksi klik upgrade manual dari UI game lu lewat Mouse Click
        recordConnection = LocalPlayer:GetMouse().Button1Down:Connect(function()
            task.wait(0.1) -- Tunggu remote asli game jalan duluan
            local tower = AmbilTowerDariMouse(currentFolder)
            if tower then
                local p = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
                if p then
                    table.insert(MacroData, {
                        Type = "Upgrade",
                        Time = os.clock() - StartTime,
                        X = p.Position.X,
                        Y = p.Position.Y,
                        Z = p.Position.Z
                    })
                    updateStatus("Upgrade Captured!")
                end
            end
        end)
    else
        isRecording = false
        if recordConnection then recordConnection:Disconnect() recordConnection = nil end
        RecordBtn.Text = "START RECORD"
        RecordBtn.BackgroundColor3 = Color3.fromRGB(35, 25, 50)
        updateStatus("Saved " .. #MacroData .. " actions.")
        
        if #MacroData > 0 and writefile then
            writefile(FILE_NAME, HttpService:JSONEncode(MacroData))
        end
    end
end)

buatTombol("LOAD MACRO DATA", 130, function()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        updateStatus("Loaded " .. #MacroData .. " actions.")
    else
        updateStatus("No saved file found!")
    end
end)

buatTombol("RUN PLAYBACK", 180, function()
    if #MacroData == 0 then updateStatus("No data to play!") return end
    updateStatus("Playing automation...")
    
    task.spawn(function()
        local pStart = os.clock()
        local currentFolder = dapatkanFolderTower()
        local upgradeRemote = ReplicatedStorage.Events:FindFirstChild("UpgradeTower")
        
        for i = 1, #MacroData do
            local move = MacroData[i]
            while (os.clock() - pStart) < move.Time do task.wait(0.02) end
            
            if move.Type == "Upgrade" and upgradeRemote then
                -- Cari ID Tower terdekat berdasarkan posisi saat direkam
                local targetPos = Vector3.new(move.X, move.Y, move.Z)
                local jarakTerdekat = math.huge
                local liveUID = nil
                
                for _, t in pairs(currentFolder:GetChildren()) do
                    local bp = t:FindFirstChildWhichIsA("BasePart") or t.PrimaryPart
                    if bp then
                        local dist = (bp.Position - targetPos).Magnitude
                        if dist < jarakTerdekat and dist < 6 then
                            jarakTerdekat = dist
                            local uidVal = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                            liveUID = uidVal and uidVal.Value or t.Name
                        end
                    end
                end
                
                if liveUID then
                    upgradeRemote:InvokeServer(liveUID)
                    updateStatus("Upgraded action " .. i)
                end
            end
        end
        updateStatus("Playback Finished!")
    end)
end)
