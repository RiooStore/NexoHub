-- =========================================================================
-- CORE CORE DETECTOR: MENYADAP FUNGSI INTERNAL GAME MURNI
-- =========================================================================
local spawnHook = nil
local gameHook = nil

local function StartPureRecording()
    MacroData = {}
    StartTime = os.clock()
    local towerFolder = getTowerFolder()
    
    -- 1. Deteksi Fungsi Spawn (Melihat saat Unit Baru Ditambahkan ke Game)
    spawnHook = towerFolder.ChildAdded:Connect(function(child)
        if not isRecording then return end
        task.wait(0.05) -- Jeda mikro agar properti unit ter-load sempurna oleh game
        local primary = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
        if primary then
            local uidValue = child:FindFirstChild("UID") or child:FindFirstChild("Id")
            local savedUID = uidValue and uidValue.Value or "default_uid"
            
            table.insert(MacroData, {
                Type = "Spawn",
                Time = os.clock() - StartTime,
                X = primary.Position.X,
                Y = primary.Position.Y,
                Z = primary.Position.Z,
                UID = savedUID
            })
            setStatus("Recorded: Spawn Unit!")
        end
    end)
    
    -- 2. Deteksi Fungsi Upgrade & Jual (Menyadap Jalur Komunikasi Game ke Server)
    -- Menggunakan metatable hooking tingkat tinggi yang aman dari deteksi game
    local rawMT = getrawmetatable(game)
    setreadonly(rawMT, false)
    local oldNamecall = rawMT.__namecall
    
    gameHook = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if isRecording and (method == "InvokeServer" or method == "FireServer") then
            -- Deteksi Fungsi Upgrade
            if self.Name == "UpgradeTower" and args[1] then
                local targetUID = args[1]
                -- Cari posisi unit berdasarkan UID-nya saat ini di map
                local x, y, z = 0, 0, 0
                for _, t in pairs(towerFolder:GetChildren()) do
                    local id = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                    if id and id.Value == targetUID then
                        local part = t.PrimaryPart or t:FindFirstChildWhichIsA("BasePart")
                        if part then x, y, z = part.Position.X, part.Position.Y, part.Position.Z end
                        break
                    end
                end
                
                table.insert(MacroData, {
                    Type = "Upgrade",
                    Time = os.clock() - StartTime,
                    X = x, Y = y, Z = z,
                    UID = targetUID
                })
                setStatus("Recorded: Upgrade Unit!")
                
            -- Deteksi Fungsi Jual (Sell)
            elseif (self.Name == "SellTower" or self.Name == "Sell") and args[1] then
                local targetUID = args[1]
                local x, y, z = 0, 0, 0
                for _, t in pairs(towerFolder:GetChildren()) do
                    local id = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                    if id and id.Value == targetUID then
                        local part = t.PrimaryPart or t:FindFirstChildWhichIsA("BasePart")
                        if part then x, y, z = part.Position.X, part.Position.Y, part.Position.Z end
                        break
                    end
                end
                
                table.insert(MacroData, {
                    Type = "Sell",
                    Time = os.clock() - StartTime,
                    X = x, Y = y, Z = z,
                    UID = targetUID
                })
                setStatus("Recorded: Sell Unit!")
            end
        end
        return oldNamecall(self, ...)
    end))
end

local function StopPureRecording()
    if spawnHook then spawnHook:Disconnect() spawnHook = nil end
    -- Mengembalikan fungsi namecall bawaan game agar tidak bocor/lag
    if gameHook then
        local rawMT = getrawmetatable(game)
        setreadonly(rawMT, false)
        rawMT.__namecall = gameHook
        gameHook = nil
    end
end

-- =========================================================================
-- PLAYBACK ENGINE (PRESISI TINGGI & PENEMPATAN SAMA PERSIS)
-- =========================================================================
local function PlayPureMacro()
    if #MacroData == 0 then setStatus("No data to play!") return end
    setStatus("Playing Automation...")
    
    task.spawn(function()
        -- Urutkan data berdasarkan waktu agar tidak tertukar susunannya
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        local towerFolder = getTowerFolder()
        
        for i = 1, #MacroData do
            local step = MacroData[i]
            
            -- Sinkronisasi Waktu Menggunakan Kalkulasi Delta Waktu Murni (Presisi Milidetik)
            while (os.clock() - playbackStart) < step.Time do
                task.wait()
            end
            
            local targetPos = Vector3.new(step.X, step.Y, step.Z)
            
            if step.Type == "Spawn" then
                local placeRemote = getGameRemote("PlaceTower") or getGameRemote("Place")
                if placeRemote then
                    task.spawn(function()
                        if placeRemote:IsA("RemoteFunction") then 
                            placeRemote:InvokeServer(targetPos, step.UID, 0) 
                        else 
                            placeRemote:FireServer(targetPos, step.UID, 0) 
                        end
                    end)
                    setStatus("Executed Spawn ["..i.."]")
                end
                
            elseif step.Type == "Upgrade" or step.Type == "Sell" then
                -- Cari UID unit live yang posisinya paling pas dengan koordinat saat direkam
                local liveUID = nil
                local closestDist = math.huge
                for _, t in pairs(towerFolder:GetChildren()) do
                    local bp = t:FindFirstChildWhichIsA("BasePart") or t.PrimaryPart
                    if bp then
                        local dist = (bp.Position - targetPos).Magnitude
                        if dist < closestDist and dist < 5 then
                            closestDist = dist
                            local id = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                            liveUID = id and id.Value or t.Name
                        end
                    end
                end
                
                if liveUID then
                    local targetRemoteName = (step.Type == "Upgrade") and "UpgradeTower" or "SellTower"
                    local remote = getGameRemote(targetRemoteName) or getGameRemote("Sell")
                    if remote then
                        task.spawn(function()
                            if remote:IsA("RemoteFunction") then remote:InvokeServer(liveUID) else remote:FireServer(liveUID) end
                        end)
                        setStatus("Executed "..step.Type.." ["..i.."]")
                    end
                end
            end
        end
        setStatus("Macro Playback Finished!")
    end)
end

