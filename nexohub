local function jalankanPlayback()
    if #MacroData == 0 then return end
    appendZoneLog("Play", "Deploying UID matching playback...")
    task.spawn(function()
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            while (os.clock() - playbackStart) < step.Time do task.wait(0.01) end
            
            if step.Type == "Spawn" then
                local placeRemote = getSafeRemote("PlaceTower") or getSafeRemote("Place")
                if placeRemote then
                    local finalArgs = {[1] = Vector3.new(step.X, step.Y, step.Z), [2] = step.SavedUID, [3] = 0}
                    task.spawn(function()
                        if placeRemote:IsA("RemoteFunction") then placeRemote:InvokeServer(unpack(finalArgs)) else placeRemote:FireServer(unpack(finalArgs)) end
                    end)
                    appendZoneLog("Spawn", string.format("Placed sequence %d.", index))
                end
            elseif step.Type == "Upgrade" then
                local upgradeRemote = getSafeRemote("UpgradeTower")
                if upgradeRemote then
                    -- Cari UID baru dari tower yang ada di posisi koordinat ini saat ini
                    local posLacak = Vector3.new(step.X, step.Y, step.Z)
                    local freshUID = temukanUIDTowerTerdekat(posLacak)
                    
                    if freshUID then
                        task.spawn(function()
                            upgradeRemote:InvokeServer(freshUID)
                        end)
                        appendZoneLog("Upgrade", string.format("Upgraded tower at index %d using live UID.", index))
                    else
                        appendZoneLog("Error", "Could not find valid tower UID for upgrade at target location!")
                    end
                end
            end
        end
        appendZoneLog("System", "Automation sequence finished.")
    end)
end
