-- Fungsi bantu mencari tower berdasarkan UID string di game lu
local function temukanPosisiTowerDariUID(uid)
    for _, tower in pairs(TowerFolder:GetChildren()) do
        -- Mencari kecocokan nama, atribut, atau StringValue di dalam objek tower
        if tower.Name == uid or (tower:FindFirstChild("UID") and tower.UID.Value == uid) or tower:GetAttribute("UID") == uid then
            local p = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
            if p then return p.Position end
        end
    end
    -- Fallback jika game menyimpan UID langsung sebagai nama model
    local modelDirect = TowerFolder:FindFirstChild(uid)
    if modelDirect then
        local p = modelDirect.PrimaryPart or modelDirect:FindFirstChildWhichIsA("BasePart")
        if p then return p.Position end
    end
    return nil
end

-- Fungsi bantu playback mencari UID tower baru terdekat berdasarkan posisi koordinat asal
local function temukanUIDTowerTerdekat(posRecord)
    local jarakTerdekat = math.huge
    local uidTerpilih = nil
    
    for _, tower in pairs(TowerFolder:GetChildren()) do
        local p = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
        if p then
            local jarak = (p.Position - posRecord).Magnitude
            if jarak < jarakTerdekat and jarak < 5 then -- Batas toleransi jarak 5 studs
                jarakTerdekat = jarak
                -- Ambil UID barunya
                local uidValue = tower:FindFirstChild("UID") or tower:FindFirstChild("Id")
                if uidValue then
                    uidTerpilih = uidValue.Value
                else
                    uidTerpilih = tower.Name -- Fallback jika nama model adalah UID-nya
                end
            end
        end
    end
    return uidTerpilih
end

local function AktifkanV33Engine()
    -- 1. TRACK PLACE VIA WORKSPACE (Sangat Akurat)
    if TowerFolder then
        placeConnection = TowerFolder.ChildAdded:Connect(function(child)
            if not isRecording then return end
            task.wait(0.1)
            local ownerCheck = child:FindFirstChild("Owner") or child:FindFirstChild("Player")
            if ownerCheck and ownerCheck.Value ~= LocalPlayer.Name then return end
            
            local primaryPart = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
            if primaryPart then
                local currentDelay = os.clock() - StartTime
                -- Dapatkan UID bawaan tower baru jika ada
                local towerUID = child.Name
                local uidObj = child:FindFirstChild("UID") or child:FindFirstChild("Id")
                if uidObj then towerUID = uidObj.Value end

                table.insert(MacroData, {
                    Type = "Spawn",
                    Time = currentDelay,
                    X = primaryPart.Position.X,
                    Y = primaryPart.Position.Y,
                    Z = primaryPart.Position.Z,
                    SavedUID = LastSelectedUnitUID,
                    TowerUID = towerUID -- Disimpan untuk cross-reference
                })
                appendZoneLog("Place", "Placement logged completely.")
            end
        end)
    end

    -- 2. DETEKSI UPGRADE VIA METATABLE HOOK KARENA MENGGUNAKAN INVOKESERVER
    if not isHookInstalled then
        isHookInstalled = true
        local upgradeRemote = getSafeRemote("UpgradeTower")
        if upgradeRemote then
            local gMetatable = feeling and getrawmetatable(game) or debug.getmetatable(game)
            if setreadonly then setreadonly(gMetatable, false) end
            local originalNamecall = gMetatable.__namecall
            
            gMetatable.__namecall = newcclosure(function(self, ...)
                local method = getnamecallmethod()
                local args = {...}
                
                if isRecording and self == upgradeRemote and (method == "InvokeServer" or method == "FireServer") then
                    local targetUID = args[1]
                    if typeof(targetUID) == "string" then
                        -- Lacak koordinat tower di Workspace yang punya UID ini
                        local posObj = temukanPosisiTowerDariUID(targetUID)
                        
                        -- Jika tidak ketemu di folder tower, ambil fallback dari posisi mouse
                        if not posObj then
                            local m = LocalPlayer:GetMouse()
                            if m then posObj = m.Hit.Position end
                        end

                        if posObj then
                            local currentDelay = os.clock() - StartTime
                            table.insert(MacroData, {
                                Type = "Upgrade",
                                Time = currentDelay,
                                X = posObj.X,
                                Y = posObj.Y,
                                Z = posObj.Z
                            })
                            appendZoneLog("Upgrade", "Upgrade captured via Tower UID Reference!")
                        end
                    end
                end
                return originalNamecall(self, ...)
             gMetatable.__namecall)
        end
    end
end

