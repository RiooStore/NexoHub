-- AUTO LOOP INSTANT LOAD
task.spawn(function()
    task.wait(3)
    local suksesLoad = muatDataMakro()
    if suksesLoad and isfile and isfile("rioo_autoreplay_state.txt") then
        local state = readfile("rioo_autoreplay_state.txt")
