-- Smart Recording Button
local RecordBtn
RecordBtn = createZoneButton("START MACRO RECORD", UDim2.new(0, 10, 0, 35), UDim2.new(1, -20, 0, 32), LeftBox, function()
    if not isRecording then
        MacroData = {}
        StartTime = os.clock()
        isRecording = true
        
        RecordBtn.Text = "🛑 STOP RECORDING"
        RecordBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        appendZoneLog("System", "Recording started.")
        
        local clickCon
        clickCon = game:GetService("UserInputService").InputBegan:Connect(function(input, processed)
            if not isRecording then clickCon:Disconnect() return end
            if processed then return end
            
            if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and canRecordClick then
                canRecordClick = false
                local currentDelay = os.clock() - StartTime
                local exactPos = Mouse.Hit.Position 
                
                table.insert(MacroData, {Type = "Spawn", Time = currentDelay, X = exactPos.X, Y = exactPos.Y, Z = exactPos.Z, SavedUID = LastDetectedUID})
                appendZoneLog("Spawn", "Position buffered.")
                
                task.wait(1.2)
                canRecordClick = true
            end
        end)
    else
        isRecording = false
        RecordBtn.Text = "START MACRO RECORD"
        RecordBtn.TextColor3 = Color3.fromRGB(240, 240, 240)
        appendZoneLog("System", string.format("Recording saved! Sequences: %d", #MacroData))
        
        if #MacroData > 0 and writefile then
            writefile(FILE_NAME, HttpService:JSONEncode(MacroData))
        end
    end
end)

local function muatDataMakro()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        appendZoneLog("Load", string.format("Loaded macro file. %d sequences armed.", #MacroData))
        return true
    end
    return false
end
createZoneButton("LOAD DATA FROM TEXT", UDim2.new(0, 10, 0, 75), UDim2.new(1, -20, 0, 32), LeftBox, muatDataMakro)

local function jalankanPlayback()
    if #MacroData == 0 then return end
    appendZoneLog("Play", "Running macro playback...")
    task.spawn(function()
        if speedToggleActive then paksaSpeedGame(currentSpeedSetting) end
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        
        if autoVoteReadyEnabled then
            local voteRemote = getSafeRemote("VoteDifficulty")
            if voteRemote then
                voteRemote:FireServer(targetDifficulty)
                appendZoneLog("Vote", "Difficulty selected: " .. targetDifficulty)
            end
            task.wait(0.5) 
            local readyRemote = getSafeRemote("Ready")
            if readyRemote then
                readyRemote:FireServer()
                appendZoneLog("Ready", "State forced to READY.")
            end
        end
        
        for index = 1, #MacroData do
            local step = MacroData[index]
            local adjustedTime = speedToggleActive and (step.Time / 1.5) or step.Time
            while (os.clock() - playbackStart) < adjustedTime do task.wait(0.01) end
            
            local placeRemote = getSafeRemote("PlaceTower")
            if step.Type == "Spawn" and placeRemote then
                local finalArgs = {
                    [1] = Vector3.new(step.X, step.Y, step.Z),
                    [2] = step.SavedUID or LastDetectedUID, 
                    [3] = 0
                }
                task.spawn(function() placeRemote:InvokeServer(unpack(finalArgs)) end)
                appendZoneLog("Spawn", string.format("Sequence %d injected.", index))
            end
        end
        
        appendZoneLog("System", "All sequences deployed.")
        
        if autoReplayEnabled then
            while autoReplayEnabled do
                task.wait(4)
                local replayRemote = getSafeRemote("PlayAgain")
                if replayRemote then
                    replayRemote:FireServer()
                    appendZoneLog("Replay", "Executing PlayAgain remote!")
                    break
                end
            end
        end
    end)
end
createZoneButton("RUN AUTOMATION", UDim2.new(0, 10, 0, 115), UDim2.new(1, -20, 0, 32), LeftBox, jalankanPlayback)

