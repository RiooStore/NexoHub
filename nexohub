-- =========================================================================
-- SAFE PURE DETECTOR ENGINE (MURNI TRACKING WORKSPACE)
-- =========================================================================
local towerConnections = {}
local folderConnection = nil

local function trackTowerFunctions(tower)
    -- Deteksi UPGRADE via Perubahan Level (Membaca data internal game secara pasif)
    local upgradeSignal = tower:FindFirstChild("Level") or tower:FindFirstChild("Upgrade")
    if upgradeSignal and upgradeSignal:IsA("ValueBase") then
        towerConnections[tower.Name.."_upg"] = upgradeSignal.Changed:Connect(function()
            if not isRecording then return end
            local p = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
            if p then
                table.insert(MacroData, {
                    Type = "Upgrade",
                    Time = os.clock() - StartTime,
                    X = p.Position.X, Y = p.Position.Y, Z = p.Position.Z
                })
                setStatus("Recorded: Upgrade Fungsi Game!")
            end
        end)
    end
end

local function StartPureRecording()
    MacroData = {}
    StartTime = os.clock()
    local folder = getTowerFolder()
    
    -- 1. Deteksi SPAWN
    folderConnection = folder.ChildAdded:Connect(function(child)
        if not isRecording then return end
        task.wait(0.05)
        local p = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart")
        if p then
            local uidVal = child:FindFirstChild("UID") or child:FindFirstChild("Id")
            local actualUID = uidVal and uidVal.Value or "ffc541d5-ef02-4a69-8045-6a3d97bda308"
            
            table.insert(MacroData, {
                Type = "Spawn",
                Time = os.clock() - StartTime,
                X = p.Position.X, Y = p.Position.Y, Z = p.Position.Z,
                UID = actualUID
            })
            setStatus("Recorded: Spawn Fungsi Game!")
            trackTowerFunctions(child)
        end
    end)
    
    -- Amati juga tower yang mendadak hilang/dijual (SELL)
    for _, tower in pairs(folder:GetChildren()) do
        trackTowerFunctions(tower)
        towerConnections[tower.Name.."_del"] = tower.AncestryChanged:Connect(function(_, parent)
            if not isRecording and not parent then
                local p = tower:FindFirstChild("HumanoidRootPart") or tower.PrimaryPart
                if p then
                    table.insert(MacroData, {
                        Type = "Sell",
                        Time = os.clock() - StartTime,
                        X = p.Position.X, Y = p.Position.Y, Z = p.Position.Z
                    })
                    setStatus("Recorded: Jual Fungsi Game!")
                end
            end
        end)
    end
end

local function StopPureRecording()
    if folderConnection then folderConnection:Disconnect() folderConnection = nil end
    for k, conn in pairs(towerConnections) do conn:Disconnect() towerConnections[k] = nil end
end

-- =========================================================================
-- PLAYBACK ENGINE (DELTA TIMING SINKRONASI PRESISI)
-- =========================================================================
local function PlayPureMacro()
    if #MacroData == 0 then setStatus("No macro data loaded!") return end
    setStatus("Playing Back Macro...")
    
    task.spawn(function()
        table.sort(MacroData, function(a, b) return a.Time < b.Time end)
        local playbackStart = os.clock()
        local folder = getTowerFolder()
        
        for i = 1, #MacroData do
            local step = MacroData[i]
            
            -- Waktu 100% Sesuai Detik Saat Record (Delta Sync)
            while (os.clock() - playbackStart) < step.Time do
                task.wait()
            end
            
            local targetPos = Vector3.new(step.X, step.Y, step.Z)
            
            if step.Type == "Spawn" then
                local remote = getGameRemote("PlaceTower") or getGameRemote("Place")
                if remote then
                    task.spawn(function()
                        if remote:IsA("RemoteFunction") then remote:InvokeServer(targetPos, step.UID, 0) else remote:FireServer(targetPos, step.UID, 0) end
                    end)
                    setStatus("Executed Spawn ["..i.."]")
                end
                
            elseif step.Type == "Upgrade" or step.Type == "Sell" then
                -- Cari ID live unit terdekat dari koordinat rekaman
                local liveUID = nil
                local closestDist = math.huge
                for _, t in pairs(folder:GetChildren()) do
                    local bp = t:FindFirstChildWhichIsA("BasePart") or t.PrimaryPart
                    if bp then
                        local dist = (bp.Position - targetPos).Magnitude
                        if dist < closestDist and dist < 5 then
                            closestDist = dist
                            local id = t:FindFirstChild("UID") or t:FindFirstChild("Id")
                            liveUID = id and id.Value or t.Name
                        end
                    end
                end
                
                if liveUID then
                    local remoteName = (step.Type == "Upgrade") and "UpgradeTower" or "SellTower"
                    local remote = getGameRemote(remoteName) or getGameRemote("Sell")
                    if remote then
                        task.spawn(function()
                            if remote:IsA("RemoteFunction") then remote:InvokeServer(liveUID) else remote:FireServer(liveUID) end
                        end)
                        setStatus("Executed "..step.Type.." ["..i.."]")
                    end
                end
            end
        end
        setStatus("Playback Finished Completely!")
    end)
end

