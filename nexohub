-- REAL-TIME REMOTE LISTENER CRITICAL ENGINE
-- =========================================================================
local function paksaSpeedGame(targetSpeed)
    if SpeedEvent then
        task.spawn(function()
            SpeedEvent:FireServer(targetSpeed)
            task.wait(0.2)
            SpeedEvent:FireServer(targetSpeed)
        end)
    end
end

-- HOOK REMOTES (Mendeteksi pasang & upgrade dari game murni, bukan klik layar)
if PlaceEvent and PlaceEvent.ClassName == "RemoteEvent" then
    PlaceEvent.OnClientEvent:Connect(function(...)
        if isRecording then
            local args = {...}
            spawnedUnitsCount = spawnedUnitsCount + 1
            local timestamp = os.clock() - StartTime
            
            table.insert(MacroData, {Type = "Spawn", Time = timestamp, Args = args, Id = spawnedUnitsCount})
            tambahLogBaris(string.format("[OK] Placed: Unit [S] id=%d", spawnedUnitsCount))
        end
    end)
elseif PlaceEvent and PlaceEvent.ClassName == "RemoteFunction" then
    -- Jika sistem game pakai RemoteFunction, di-hook saat server membalas data
    tambahLogBaris("[SYSTEM] Event Hook Active.")
end

-- Menangkap Aksi Upgrade Langsung dari Sinyal Game
if UpgradeEvent then
    local function registerUpgrade(id, level)
        if isRecording then
            local timestamp = os.clock() - StartTime
            table.insert(MacroData, {Type = "Upgrade", Time = timestamp, TargetId = id, NextLv = level})
            tambahLogBaris(string.format("[OK] Upgraded slot %d -> lv%d", id, level))
        end
    end
    
    if UpgradeEvent.ClassName == "RemoteEvent" then
        UpgradeEvent.OnClientEvent:Connect(function(id, level)
            registerUpgrade(id or 1, level or 2)
        end)
    end
end

