        setStatus("Saved " .. #MacroData .. " actions.")
        if #MacroData > 0 and writefile then
            writefile(FILE_NAME, HttpService:JSONEncode(MacroData))
        end
    end
end)

createButton("LOAD RECORD DATA", 125, function()
    if readfile and isfile and isfile(FILE_NAME) then
        MacroData = HttpService:JSONDecode(readfile(FILE_NAME))
        setStatus("Loaded " .. #MacroData .. " actions successfully.")
    else
        setStatus("No macro file found on device.")
    end
end)

createButton("RUN PLAYBACK (AUTO)", 170, function()
    PlayPureMacro()
end)
