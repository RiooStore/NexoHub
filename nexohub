local function paksaSpeedGame(targetSpeed)
    local speedRemote = getSafeRemote("RequestGameSpeed")
    if speedRemote then
        task.spawn(function()
            speedRemote:FireServer(targetSpeed)
            task.wait(0.15)
            speedRemote:FireServer(targetSpeed)
        end)
    end
end

