-- === RIOOHUB V36 (SUPER STRIPPED - CORE UI RECOVERY) ===
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
if not LocalPlayer then
    Players:GetPropertyChangedSignal("LocalPlayer"):Wait()
    LocalPlayer = Players.LocalPlayer
end

-- PAKSA PAKAI PLAYERGUI BIAR WORK DI SEMUA EXECUTOR MOBILE/PC
local TargetGui = LocalPlayer:WaitForChild("PlayerGui")

if TargetGui:FindFirstChild("RiooHub_ZoneEngine") then 
    TargetGui.RiooHub_ZoneEngine:Destroy() 
end

local FILE_NAME = "rioo_precise_macro.txt"
local isRecording = false
local StartTime = 0
local MacroData = {}

-- Deteksi Folder Tower secara aman saat merekam saja (biar ga crash di awal)
local function dapatkanFolderTower()
    return Workspace:FindFirstChild("Towers") 
        or Workspace:FindFirstChild("Units") 
        or Workspace:FindFirstChild("PlacedTowers") 
        or Workspace:FindFirstChild("TowersFolder")
        or Workspace
end

